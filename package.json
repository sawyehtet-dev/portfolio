{
    "name": "sawyehtet-com",
    "version": "3.0.0",
    "description": "Personal site of Saw Ye Htet: an editorial portfolio and writing feed built with React, TypeScript, and Vite, with the earlier GNOME desktop simulation preserved at /desktop",
    "type": "module",
    "main": "index.html",
    "scripts": {
        "dev": "vite",
        "build": "npm run typecheck && npm run generate:feeds && vite build && npm run generate:meta",
        "generate:feeds": "node scripts/generate-feeds.mjs",
        "generate:meta": "node scripts/generate-meta.mjs",
        "preview": "vite preview",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --config vitest.config.js",
        "test:watch": "vitest --config vitest.config.js",
        "validate": "npm run lint && npm run typecheck && npm run test",
        "generate:og": "node scripts/generate-og.mjs"
    },
    "keywords": [
        "portfolio",
        "personal-site",
        "writing",
        "blog",
        "rss",
        "editorial-design",
        "typography",
        "react",
        "typescript",
        "vite",
        "tailwindcss",
        "react-router",
        "modern-css"
    ],
    "author": "Saw Ye Htet <sawyehtet.dev@gmail.com>",
    "license": "MIT",
    "devDependencies": {
        "@axe-core/react": "^4.11.3",
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.59.0",
        "@vitejs/plugin-react": "^6.0.2",
        "eslint": "^10.5.0",
        "eslint-plugin-security": "^4.0.1",
        "globals": "^17.6.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.4",
        "puppeteer": "^25.1.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.9"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sawyehtet-dev/portfolio.git"
    },
    "homepage": "https://sawyehtet.com",
    "bugs": {
        "url": "https://github.com/sawyehtet-dev/portfolio/issues"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ],
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@phosphor-icons/react": "^2.1.10",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "framer-motion": "^12.39.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.73.1",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.14.2",
        "remark-gfm": "^4.0.1",
        "zod": "^4.3.6"
    }
}
